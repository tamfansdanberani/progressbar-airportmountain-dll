<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net48</TargetFramework>
    <OutputType>Library</OutputType>
    <LangVersion>latest</LangVersion>
    <AssemblyName>AirportMountain</AssemblyName>
    <RootNamespace>AirportMountain</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <!-- You must have these DLLs in your GTA V folder or a known path -->
    <!-- ScriptHookVDotNet3.dll is the most common version for modern mods -->
    <Reference Include="ScriptHookVDotNet3">
      <HintPath>D:\Epic Games\GTAV\ScriptHookVDotNet3.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="System.Drawing" />
    <Reference Include="System.Windows.Forms" />
    <Reference Include="System.Management" />
    <Reference Include="System.Net.Http" />
  </ItemGroup>

</Project>
